# ─────────────────────────────────────────────────────────────
# CENTRACHAT INTERNATIONAL – Variables d'environnement
# Copier ce fichier vers .env et renseigner vos valeurs
# ⚠️  NE JAMAIS COMMITER LE FICHIER .env SUR GITHUB
# ─────────────────────────────────────────────────────────────

# Configuration SMTP IONOS (SSL port 465)
SMTP_HOST=smtp.ionos.fr
SMTP_PORT=465
SMTP_USER=contact@centrachat.africa
SMTP_PASS=votre_mot_de_passe_ionos

# Environnement (development | production)
NODE_ENV=production

# ─── Notes de configuration IONOS ───────────────────────────
# Serveur sortant (SMTP) : smtp.ionos.fr
# Port sortant (SSL)     : 465  ← SSL doit être activé
# Authentification       : Oui (email + mot de passe)
# ─────────────────────────────────────────────────────────────
